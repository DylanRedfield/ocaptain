32 -> 35  [key=0];
32 -> 26  [key=0];
33 -> 32  [key=0];
36 -> "-1"  [key=0];
37 -> 2  [key=0];
38 -> "-1"  [key=0];
39 -> 2  [key=0];
40 -> "-1"  [key=0];
41 -> "-1"  [key=0];
42 -> "-1"  [key=0];
43 -> 6  [key=0];
44 -> "-1"  [key=0];
45 -> 6  [key=0];
46 -> "-1"  [key=0];
47 -> 48  [key=0];
49 -> 50  [key=0];
50 -> 51  [key=0];
50 -> 52  [key=0];
50 -> 53  [key=0];
50 -> 56  [key=0];
51 -> "-1"  [key=0];
52 -> "-1"  [key=0];
53 -> "-1"  [key=0];
54 -> "-1"  [key=0];
