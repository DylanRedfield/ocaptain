56 -> "-1"  [key=0];
57 -> 6  [key=0];
58 -> 6  [key=0];
59 -> "-1"  [key=0];
}
`;
    drawGraph(graph);
  } else {
    serveGraph();
  }


</script>
</body>
</html>
