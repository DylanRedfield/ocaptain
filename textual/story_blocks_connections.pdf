51 [label="checkpoint_action...", style=filled, fillcolor=lightblue, shape=box];
52 [label="checkpoint_action...", style=filled, fillcolor=lightblue, shape=box];
53 [label="checkpoint_action...", style=filled, fillcolor=lightblue, shape=box];
54 [label="action_brancher_v...", style=filled, fillcolor=lightblue, shape=box];
55 [label="action_brancher_v...", style=filled, fillcolor=lightblue, shape=box];
56 [label="checkpoint_action...", style=filled, fillcolor=lightblue, shape=box];
57 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
58 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
59 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
0 -> 1  [key=0];
0 -> 3  [key=0];
0 -> 4  [key=0];
0 -> 5  [key=0];
0 -> 7  [key=0];
0 -> 8  [key=0];
0 -> 10  [key=0];
0 -> 11  [key=0];
