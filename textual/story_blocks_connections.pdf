20 [label=checkpoint_general];
21 [label="action_blank_chec...", style=filled, fillcolor=lightblue, shape=box];
22 [label="action_blank_chec...", style=filled, fillcolor=lightblue, shape=box];
23 [label="action_blank_chec...", style=filled, fillcolor=lightblue, shape=box];
24 [label="action_blank_chec...", style=filled, fillcolor=lightblue, shape=box];
25 [label="checkpoint_to_fil...", style=filled, fillcolor=lightblue, shape=box];
26 [label=GENR_CYCL_CONN_af115, style=filled, fillcolor="#d22dc2"];
27 [label=GENR_CYCL_CONN_0f797, style=filled, fillcolor="#783a51"];
28 [label="checkpoint_to_fil...", style=filled, fillcolor=lightblue, shape=box];
29 [label=GENR_CYCL_SRC_af115, style=filled, fillcolor="#d22dc2"];
30 [label=GENR_CYCL_SRC_0f797, style=filled, fillcolor="#783a51"];
31 [label=GENR_CYCL_SINK_0f797, style=filled, fillcolor="#783a51"];
32 [label="checkpoint_to_fil...", style=filled, fillcolor=lightblue, shape=box];
33 [label=GENR_CYCL_SRC_79998, style=filled, fillcolor="#3a786d"];
34 [label=GENR_CYCL_SINK_79998, style=filled, fillcolor="#3a786d"];
35 [label=GENR_CYCL_SINK_af115, style=filled, fillcolor="#d22dc2"];
36 [label="checkpoint_with_p...", style=filled, fillcolor=lightblue, shape=box];
37 [label="checkpoint_with_p...", style=filled, fillcolor=lightblue, shape=box];
38 [label="checkpoint_with_p...", style=filled, fillcolor=lightblue, shape=box];
39 [label="checkpoint_with_p...", style=filled, fillcolor=lightblue, shape=box];
40 [label="Generated Story -...", style=filled, fillcolor=lightblue, shape=box];
41 [label="checkpoint_to_fil...", style=filled, fillcolor=lightblue, shape=box];
42 [label="checkpoint_to_fil...", style=filled, fillcolor=lightblue, shape=box];
43 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
44 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
45 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
46 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
47 [label="action_brancher_w...", style=filled, fillcolor=lightblue, shape=box];
48 [label="checkpoint_with_t..."];
